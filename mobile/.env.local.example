# 복사: cp .env.local.example .env.local
#
# iOS 시뮬레이터 / Android 에뮬레이터(호스트 맥의 백엔드):
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
#
# 네이티브 빌드 (npm run android / expo run:android): Android SDK 경로 필요.
# macOS + Android Studio 기본: ~/Library/Android/sdk
#   export ANDROID_HOME=$HOME/Library/Android/sdk
# 또는 `npx expo prebuild --platform android` 후 `android/local.properties` 에:
#   sdk.dir=/Users/본인계정/Library/Android/sdk
#
# 실제 폰(Expo Go)에서 맥의 bootRun에 붙이려면 localhost는 안 됨(폰=자기 자신).
# → 공개 HTTPS 터널(ngrok 등) 하나로 API+OAuth redirect URI까지 통일하거나,
# → OAuth/API 검증은 시뮬레이터에서만 진행.
