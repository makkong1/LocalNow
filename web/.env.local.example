# Backend API base URL (server-side only, not exposed to browser)
BACKEND_BASE_URL=http://localhost:8081
# Google OAuth2: backend에 GOOGLE_OAUTH2_CLIENT_ID/SECRET, Google Cloud "승인된 리디렉션 URI"에
#   http://localhost:8081/login/oauth2/code/google
# 웹 BFF: GET /api/auth/google → 백엔드 OAuth2 시작, 완료 후 /oauth/callback#access_token=...

# WebSocket URL (NEXT_PUBLIC_ prefix allows browser access — only WS URL is exposed, auth is token-based)
NEXT_PUBLIC_WS_URL=http://localhost:8081/ws

# GitHub OAuth2: 백엔드에 GITHUB_CLIENT_ID, GITHUB_CLIENT_SECRET (application-local)
#   GitHub OAuth App "Authorization callback": http://localhost:8081/login/oauth2/code/github
# 웹 BFF: GET /api/auth/github → /oauth2/authorization/github
